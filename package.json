  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:record": "playwright test --headed",
    "test:e2e:scenario": "playwright test --project=mobile-chrome --grep \"$npm_config_grep\"",
    "test:e2e:home": "playwright test --project=mobile-chrome --grep \"홈 진입 시 인기글 섹션과 카드가 표시된다|하단 네비게이션으로 검색 페이지로 이동한다\"",
    "test:e2e:detail": "playwright test --project=mobile-chrome --grep \"홈 카드에서 상세 페이지로 이동하고 뒤로가기를 할 수 있다|검색 결과에서 상세 페이지로 이동한다\"",
    "test:e2e:mypage": "playwright test --project=mobile-chrome --grep \"마이페이지 메뉴와 사용자 정보가 표시된다\"",
    "test:e2e:faq": "playwright test --project=mobile-chrome --grep \"FAQ 페이지로 이동하고 상단바를 볼 수 있다|하단 탭바로 마이페이지 이동 후 FAQ로 진입할 수 있다\"",
    "test:e2e:nav": "playwright test --project=mobile-chrome --grep \"하단 네비게이션으로 검색 페이지로 이동한다|하단 탭바로 마이페이지 이동 후 FAQ로 진입할 수 있다\"",
    "test:e2e:report": "playwright show-report",
    "eject": "react-scripts eject",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 60
      },
      "./src/utils/": {
        "lines": 90,
        "functions": 90,
        "branches": 90
      },
      "./src/hooks/": {
        "lines": 90,
        "functions": 90,
        "branches": 90
      },
      "./src/store/": {
        "lines": 90,
        "functions": 90,
        "branches": 90
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "src/mocks/",
      "src/__mocks__/",
      "src/reportWebVitals.js",
      "src/serviceWorkerRegistration.js",
      "src/service-worker.js",
      "src/index.js"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|svg|ico)$": "<rootDir>/src/__mocks__/fileMock.js",
      "@vercel/analytics(.*)": "<rootDir>/src/__mocks__/vercelAnalytics.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(axios)/)"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.3",
    "globals": "^15.14.0",
    "msw": "^1.3.5",
    "prettier": "^3.4.2"
  }
}
